# Cache-Control headers for Netlify / Cloudflare Pages.
#
# NOTE: GitHub Pages (where this site is currently hosted) does NOT read this
# file — it always serves static assets with `Cache-Control: max-age=600`.
# This file takes effect only if the site is deployed to Netlify or
# Cloudflare Pages. While on GitHub Pages, put Cloudflare in front of the
# domain and set equivalent Cache Rules instead (see README / audit notes).

# Fingerprinted/rarely-changing binary assets — cache hard for 1 year.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/projects/*
  Cache-Control: public, max-age=31536000, immutable

# View pages are HTML and may be redeployed more often than the static
# assets under /projects/ - override with a short cache.
/projects/*/*-view.html
  Cache-Control: public, max-age=3600

/assets/favicon/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS are not content-hashed, so cache for 1 week and revalidate.
/assets/css/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/assets/js/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# HTML should always be revalidated so deploys go live immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
