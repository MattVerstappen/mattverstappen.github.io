{
  "name": "matthewderekrall-site",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio for Matthew Derek Rall (plain HTML/CSS/JS).",
  "scripts": {
    "minify:js": "terser assets/js/translations.js -o assets/js/translations.min.js --compress --mangle",
    "build": "npm run minify:js",
    "deploy": "wrangler deploy",
    "new-project": "node scripts/new-project.js",
    "manager": "node scripts/project-manager.js",
    "generate": "node scripts/generate.js",
    "validate": "node scripts/validate.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "terser": "^5.31.0",
    "wrangler": "^4.0.0"
  }
}
